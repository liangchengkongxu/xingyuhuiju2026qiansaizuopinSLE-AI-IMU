    pl->addWidget(pt1);
    auto *pt2 = new QLabel(QStringLiteral("选择技能、观看教学视频，进行专项动作练习。"));
    pt2->setStyleSheet("font-size:17px; background:transparent; color:#9eb7de;");
    pt2->setAlignment(Qt::AlignCenter);
    pt2->setWordWrap(true);
    pl->addWidget(pt2);
    connect(practiceBtn, &QPushButton::clicked, mw, [mw]() {
