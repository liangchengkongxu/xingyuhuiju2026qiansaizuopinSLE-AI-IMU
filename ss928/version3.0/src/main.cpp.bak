    matchBtn->setSizePolicy(QSizePolicy::Expanding, QSizePolicy::Preferred);
    matchBtn->setCursor(Qt::PointingHandCursor);
    matchBtn->setStyleSheet(R"(
        QPushButton {
            border: 1px solid #2f6ab4; border-radius: 22px;
            background: qlineargradient(x1:0,y1:0,x2:1,y2:1, stop:0 #1d5aa1, stop:1 #123a6f);
            color: #eaf3ff; font-size: 21px; font-weight: 800; padding: 24px;
        }
        QPushButton:hover { border-color: #56baff; }
    )");
    auto *ml = new QVBoxLayout(matchBtn);
    ml->setAlignment(Qt::AlignCenter);
    auto *mt1 = new QLabel(QStringLiteral("对打 / 比赛模式"));
    mt1->setStyleSheet("font-size:34px; font-weight:900; background:transparent; color:#eaf3ff;");
    mt1->setAlignment(Qt::AlignCenter);
    ml->addWidget(mt1);
    auto *mt2 = new QLabel(QStringLiteral("双人对打或比赛计分，实时预览与动作识别。"));
    mt2->setStyleSheet("font-size:17px; background:transparent; color:#9eb7de;");
    mt2->setAlignment(Qt::AlignCenter);
    mt2->setWordWrap(true);
    ml->addWidget(mt2);
    connect(matchBtn, &QPushButton::clicked, mw, [mw]() { mw->switchPage(7); });
