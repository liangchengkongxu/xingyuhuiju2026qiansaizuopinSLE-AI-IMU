# 复制为 board.env 后修改 IP 即可用于另一块板子
# cp board.env.example board.env

# 开发板 SSH（同厂商多块板通常账号密码相同，只改 IP）
export BOARD_IP="192.168.1.168"
export BOARD_USER="root"
export BOARD_PASS="ebaina"

# 板端安装路径
export BOARD_WS73="/opt/sample/ws73"
export BOARD_BUILD_DIR="/tmp/ws73_build"

# WS73 原厂 SDK（extracted 解压目录）
# 默认：与本 kit 同级的「星闪WS73原厂SDK/extracted」
# export WS73_SDK="/path/to/星闪WS73原厂SDK/extracted"
